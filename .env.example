# =====================================================================
# Oracle AI — system configuration (.env)
# Copy to `.env` and adjust. Loaded by the app (loadEnv) and by Docker
# Compose (env_file / ${VAR} interpolation). Process env overrides these.
# =====================================================================

# --- Database (PostgreSQL + pgvector) --------------------------------
ORACLE_DB_HOST=localhost
ORACLE_DB_PORT=5432
ORACLE_DB_USER=postgres
ORACLE_DB_PASSWORD=postgres
ORACLE_DB_NAME=oracle_db
ORACLE_DB_SSL=false
# Create the database if it does not exist (needs access to the admin db).
ORACLE_DB_AUTO_CREATE=true

# Migrations are EMBEDDED in the binary and applied on startup (Oracle runs only
# what the DB ledger is missing) — there is nothing to configure.

# --- Embeddings (vector indexing) ------------------------------------
# provider: local | gemini | openai | voyage  (local = offline, zero-cost default)
ORACLE_EMBEDDING_PROVIDER=local
# Leave MODEL empty to use the provider's default (gemini-embedding-001 /
# text-embedding-3-small / voyage-3.5). Must output ORACLE_EMBEDDING_DIM dims.
ORACLE_EMBEDDING_MODEL=
ORACLE_EMBEDDING_DIM=1024
# For gemini-embedding-001, dim 1024 is requested via outputDimensionality.
GEMINI_API_KEY=
OPENAI_API_KEY=
VOYAGE_API_KEY=

# --- Consolidation -------------------------------------------------
# Consolidation is performed by the agent (no dedicated LLM). These remain
# unset unless a server-side fallback model is configured later.
ORACLE_CONSOLIDATION_MODE=agent

# --- Maintenance ---------------------------------------------------
# Deterministic sweep over memories (decay + dedup, no LLM). When true, runs
# once on startup after migrations with the default policy. Off by default so a
# restart never silently forgets memories — invoke oracle_maintenance_run
# (with dryRun to preview) instead, or turn this on for an always-on daemon.
ORACLE_MAINTENANCE_ON_STARTUP=false
# Run the sweep every N minutes while the process is alive (0 = off). Prefer a
# single daemon for this in multi-agent setups.
ORACLE_MAINTENANCE_INTERVAL_MINUTES=0

# --- Measurement harness ------------------------------------------------
# Record per-session token/compaction metrics from the hooks (oracle_metrics_*).
ORACLE_METRICS_ENABLED=true
# Experiment tag for A/B comparison — set to e.g. "oracle" vs "baseline" across
# runs, then compare with oracle_metrics_summary.
ORACLE_METRICS_LABEL=default

# --- MCP server ------------------------------------------------------
# transport: stdio | http
ORACLE_MCP_TRANSPORT=stdio
# Local HTTP endpoint for agent hooks (fire-and-forget) and HTTP MCP.
ORACLE_HTTP_HOST=127.0.0.1
ORACLE_HTTP_PORT=49500

# --- Logging ---------------------------------------------------------
# level: debug | info | warn | error
ORACLE_LOG_LEVEL=info
