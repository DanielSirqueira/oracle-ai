# Dart / Pub
.dart_tool/
.packages
build/
pubspec_overrides.yaml

# Coverage
coverage/

# IDE
.idea/
.vscode/
*.iml

# Env / secrets
.env
.env.*
!.env.example
# Local MCP config carries the embedding API key + machine-specific paths.
.mcp.json
.claude.json

# Keys / certs / credentials — never commit
*.pem
*.key
*.p12
*.pfx
id_rsa*
id_ed25519*
*.ppk
secrets/
*.secret

# Database backups / seeds — may contain sensitive memory content, so ignored
# by default. To version a shared memory bank intentionally, force-add it:
#   git add -f backups/oracle_seed.sql
backups/*.sql
backups/*.sql.tmp
!backups/.gitkeep

# OS
.DS_Store
Thumbs.db
